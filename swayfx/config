# ~/.config/sway/config

# note 4 self if something appears tiled do this:
## for_window [class="title"] floating enable

# --- variables ---

set $mod Mod4
set $left h
set $down j
set $up k
set $right l

set $term kitty

# set $menu rofi -show drun -config ~/.config/rofi/launchers/config.rasi

set $menu wofi --show drun

set $run wofi --show run

set $drun-rofi rofi -show drun

set $run-rofi rofi -show run

set $file nautilus

# --- startup ---
exec wl-paste --watch cliphist store
exec dunst

# --- style ---

# wallpaper
output * bg /home/vshark/Pictures/walls/clouds-5.jpg fill

# gaps
gaps outer 2px
gaps inner 10px

# get rid of titlebars
font pango:monospace 0.001
titlebar_padding 1
titlebar_border_thickness 0

# border size
for_window [class="^.*"] border pixel 2

# border color
# --------------------- - border -- bg --- text -- ind - ch_border
#client.focused           #8087a2 #181926 #cad3f5 #f4dbd6 #8087a2
#client.focused_inactive  #1e2030 #1e2030 #cad3f5 #939ab7 #8087a2
#client.unfocused         #1e2030 #1e2030 #cad3f5 #8087a2 #8087a2
#client.urgent            #1e2030 #181926 #cad3f5 #ee99a0 #8087a2
#client.placeholder       #1e2030 #181926 #cad3f5 #ed8796 #8087a2

#                       border    bg      text    ind   child border
client.focused          #b7bdf8 #141216 #d8cab8 #b7bdf8 #b7bdf8
client.focused_inactive #6e738d #b7bdf8 #d8cab8 #6e738d #6e738d
client.unfocused        #6e738d #b7bdf8 #d8cab8 #181926 #6e738d
client.urgent           #fcb167 #141216 #d8cab8 #fcb167 #fcb167
client.placeholder      #AC82E9 #141216 #d8cab8 #AC82E9 #AC82E9

# round windows corners
corner_radius 10

# blur
blur enable

# shadows
shadows enable

# misc
scratchpad_minimize enable
titlebar_separator disable

# mouse sensetivity

# --- keybinds ---

    # start a terminal
    bindsym $mod+Return exec $term

    # start a file manager
    bindsym $mod+backslash exec $file

    # kill focused window
    bindsym $mod+q kill
    bindsym Alt+F4 kill

    # start wofi
    #bindsym Alt+Space exec $menu

    # ditto, but run instead of drun
    #bindsym Alt+Shift+Space exec $run

    # start rofi
    bindsym Alt+Space exec $drun-rofi

    # ditto, but run
    bindsym Alt+Shift+Space exec $run-rofi

    # emoji picker
    bindsym $mod+period exec /home/vshark/progs/bin/wolf-emoji.sh

    # clipboard manager
    bindsym $mod+comma exec rofi -modi clipboard:/home/vshark/progs/bin/cliphist-rofi-img -show clipboard -show-icons

    # layout switch
    input type:keyboard {
        xkb_layout us,ru
    }

    bindsym $mod+Space input type:keyboard xkb_switch_layout next

    # drag floating windows
    floating_modifier $mod normal

    # reload the config
    bindsym $mod+Shift+c reload

    # end session
    bindsym $mod+Shift+q exec swaynag -t warning -m 'Exit sway?' -B 'Yes' 'swaymsg exit'

    # moving focus
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right

    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # move the focused window
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right

    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

    # im lwk used to the 2 fingers to right click gesture in gnome
    input type:touchpad {
        tap enabled
        tap_button_map lrm
    }

# --- workspaces ---

    # automatically assign windows to their workspaces
    assign [class="Floorp"] workspace 1:󰖟
    assign [class="Helium Browser"] workspace 1:󰖟
    assign [class="kitty"] workspace 2:
    assign [class="Visual Studio Code"] workspace 3:󰅴
    assign [class="VSCodium"] workspace 3:󰅴
    assign [class="Feishin"] workspace 4: 
    assign [class="Spotify"] workspace 4:
    assign [class="Spotify Premium"] workspace 4:
    assign [class="Telegram"] workspace 5:󰍡
    assign [class="Discord"] workspace 5:󰍡
    assign [class="Vesktop"] workspace 5:󰍡
    assign [class="Element"] workspace 5:󰍡
    assign [class="FluffyChat"] workspace 5:󰍡
    assign [class="Steam"] workspace 6:󰊖
    assign [class="Lutris"] workspace 6:󰊖
    assign [class="Modrinth App"] workspace 6:󰊖
    assign [class="Modrinth"] workspace 6:󰊖
    assign [class="Sober"] workspace 6:󰊖
    assign [class="PekoraPlayerBootstrapper"] workspace 6:󰊖
    assign [class="Roblox"] workspace 6:󰊖
    assign [class="OBS Studio"] workspace 7:
    assign [class="Files"] workspace 8:󰉋

    # switch to a workspace
    bindsym $mod+1 workspace number 1:󰖟
    bindsym $mod+2 workspace number 2:
    bindsym $mod+3 workspace number 3:󰅴
    bindsym $mod+4 workspace number 4:
    bindsym $mod+5 workspace number 5:󰍡
    bindsym $mod+6 workspace number 6:󰊖
    bindsym $mod+7 workspace number 7:
    bindsym $mod+8 workspace number 8:󰉋
    bindsym $mod+9 workspace number 9:󰇘
    bindsym $mod+0 workspace number 10:󰇘

    # move focused window to another workspace
    bindsym $mod+Shift+1 move container to workspace number 1:󰖟
    bindsym $mod+Shift+2 move container to workspace number 2:
    bindsym $mod+Shift+3 move container to workspace number 3:󰅴
    bindsym $mod+Shift+4 move container to workspace number 4:
    bindsym $mod+Shift+5 move container to workspace number 5:󰍡
    bindsym $mod+Shift+6 move container to workspace number 6:󰊖
    bindsym $mod+Shift+7 move container to workspace number 7:
    bindsym $mod+Shift+8 move container to workspace number 8:󰉋
    bindsym $mod+Shift+9 move container to workspace number 9:󰇘
    bindsym $mod+Shift+0 move container to workspace number 10:󰇘

# --- layout ---
# (i have no idea what it is, i don't use it, but it was in the default config so y not)

    bindsym $mod+b splith
    bindsym $mod+v splitv

    # Switch the current container between different layout styles
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

# --- ---

    # Make the current focus fullscreen
    bindsym $mod+f fullscreen
    bindsym F11 fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $mod+Shift+space floating toggle

    # Move focus to the parent container
    bindsym $mod+a focus parent

# --- scratchpad ---
# (basically just minimizing windows)

    # move the focused window to scratchpad
    bindsym $mod+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym $mod+plus scratchpad show

# --- resizing ---

mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# --- utils ---

    # volume keys
    bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
    bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
    bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
    bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

    # brightness keys
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
    bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
    # Special key to take a screenshot with grim
    #bindsym Print exec grim -g"$(slurp)"

# --- status bar ---
# (the config below replaces it with waybar)

bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*
